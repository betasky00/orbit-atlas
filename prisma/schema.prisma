generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  passwordHash  String?
  role          String    @default("member") // "admin" | "member"
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
  accountAccess AccountAccess[]
}

// Which connected social accounts a team member is allowed to see/use.
// Admins implicitly have access to everything, so they need no rows here.
model AccountAccess {
  id              String   @id @default(cuid())
  userId          String
  socialAccountId String
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, socialAccountId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id        String   @id @default(cuid())
  name      String
  niche     String?
  logo      String?
  color     String   @default("#6366f1")
  brandVoice String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts SocialAccount[]
  posts          Post[]
  templates      Template[]
  carouselTemplates CarouselTemplate[]
  carouselWorkflows CarouselWorkflow[]
}

model SocialAccount {
  id           String    @id @default(cuid())
  platform     String
  accountId    String
  username     String
  displayName  String?
  avatar       String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  businessId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  posts    PostAccount[]
  access   AccountAccess[]
  carouselWorkflows CarouselWorkflow[]

  @@unique([platform, accountId])
}

// A reusable visual + content blueprint for posts.
// `layout` holds the visual zones (image/text/logo positions).
// `rules` holds the AI content rules (tone, structure, hashtag count, etc.)
model Template {
  id              String   @id @default(cuid())
  businessId      String?
  socialAccountId String? // null = shared with whole workspace; else scoped to this account
  createdById     String?
  name            String
  postType        String?
  width           Int      @default(1080)
  height          Int      @default(1080)
  background      String?
  layout          String   @default("[]") // JSON array of zones
  rules           String?  // JSON content rules
  sampleImage     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  posts    Post[]
}

// Server-side Content Library item, optionally scoped to one social account.
model SavedPost {
  id              String    @id @default(cuid())
  socialAccountId String? // null = shared with whole workspace
  createdById     String?
  name            String
  caption         String?
  hashtags        String?  // space-separated
  firstComment    String?
  templateJson    String   // JSON {width,height,background,zones}
  contentJson     String   // JSON content map (incl. image data url)
  platform        String?
  scheduledAt     DateTime?
  status          String    @default("draft")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Post {
  id           String    @id @default(cuid())
  businessId   String
  templateId   String?
  caption      String?
  hashtags     String?
  firstComment String?
  mediaUrls    String    @default("[]")
  renderedUrl  String?   // final composited image (from template)
  content      String?   // JSON of the content used to fill the template
  mediaType    String    @default("image")
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  aiGenerated  Boolean   @default(false)
  source       String?   // "manual" | "news" | "template"
  sourceData   String?   // JSON: original news article / topic
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  accounts PostAccount[]
}

model PostAccount {
  id              String    @id @default(cuid())
  postId          String
  socialAccountId String
  platformPostId  String?
  status          String    @default("pending")
  error           String?
  publishedAt     DateTime?

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([postId, socialAccountId])
}


// ============================================================
// Instagram Carousel Workflow (AI-assisted, Figma-rendered)
// ============================================================

// A reusable carousel template: a set of ordered slide templates
// whose visual source of truth lives in a Figma file (see figma-plugin/).
model CarouselTemplate {
  id String @id @default(cuid())
  businessId String? // null = shared with whole workspace
  name String
  editorialStyle String? // "Educatif" | "Storytelling" | "Data" | "Conseil"
  description String?
  previewUrl String? // preview screenshot stored on Vercel Blob
  figmaFileKey String? // Figma file key to duplicate via the Figma REST API
  slideCount Int @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  slides SlideTemplate[]
  workflows CarouselWorkflow[]
}

// One slide within a CarouselTemplate. `figmaFrameName` must match the
// Figma frame name exactly so the Figma plugin can find it. `slots` is a
// JSON array of { name, kind: "text" | "image", maxChars?, instruction? }
// and each slot name must match a Figma layer named SLOT_<name>.
model SlideTemplate {
  id String @id @default(cuid())
  templateId String
  index Int
  type String? // "hook" | "context" | "data" | "conclusion" ...
  figmaFrameName String
  slots String @default("[]") // JSON array of slot definitions
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template CarouselTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, index])
}

// A single run of the 12-node carousel workflow, from the initial prompt
// to the scheduled Instagram publication. `status` drives which node/HITL
// step is currently active.
model CarouselWorkflow {
  id String @id @default(cuid())
  businessId String
  templateId String
  createdById String?
  socialAccountId String?

  status String @default("SCRAPING")
  // SCRAPING | AWAITING_SOURCES | STRUCTURING | AWAITING_OUTLINE |
  // AWAITING_IMAGES | RENDERING | AWAITING_FIGMA_EDIT | EXPORTING |
  // AWAITING_PUBLISH | SCHEDULED | PUBLISHED | FAILED

  prompt String // consigne utilisateur, ex: "Fais un carrousel sur l'eruption du Vesuve"
  config String @default("{}") // JSON: tone, langue, sourceTypes, maxSourceAgeMonths, excludedDomains
  sources String? // JSON: sources proposees puis validees (titre, url, resume, date, domaine, score)
  outline String? // JSON: { slides: [{ index, type, slots: {...} }] }
  images String? // JSON: par slide, { imageUrl, imageCredit }
  figmaFileKey String? // fichier Figma duplique pour cette publication
  figmaFileUrl String?
  renderedUrls String? // JSON: tableau d'URLs PNG (Vercel Blob) apres export
  caption String?
  hashtags String?
  scheduledAt DateTime?
  errorMessage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template CarouselTemplate @relation(fields: [templateId], references: [id])
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
}
