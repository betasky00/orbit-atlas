generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  passwordHash  String?
  role          String    @default("member") // "admin" | "member"
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
  accountAccess AccountAccess[]
}

// Which connected social accounts a team member is allowed to see/use.
// Admins implicitly have access to everything, so they need no rows here.
model AccountAccess {
  id              String   @id @default(cuid())
  userId          String
  socialAccountId String
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, socialAccountId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id        String   @id @default(cuid())
  name      String
  niche     String?
  logo      String?
  color     String   @default("#6366f1")
  brandVoice String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts SocialAccount[]
  posts          Post[]
  templates      Template[]
}

model SocialAccount {
  id           String    @id @default(cuid())
  platform     String
  accountId    String
  username     String
  displayName  String?
  avatar       String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  businessId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  posts    PostAccount[]
  access   AccountAccess[]

  @@unique([platform, accountId])
}

// A reusable visual + content blueprint for posts.
// `layout` holds the visual zones (image/text/logo positions).
// `rules` holds the AI content rules (tone, structure, hashtag count, etc.)
model Template {
  id              String   @id @default(cuid())
  businessId      String?
  socialAccountId String? // null = shared with whole workspace; else scoped to this account
  createdById     String?
  name            String
  postType        String?
  width           Int      @default(1080)
  height          Int      @default(1080)
  background      String?
  layout          String   @default("[]") // JSON array of zones
  rules           String?  // JSON content rules
  sampleImage     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  posts    Post[]
}

// Server-side Content Library item, optionally scoped to one social account.
model SavedPost {
  id              String    @id @default(cuid())
  socialAccountId String? // null = shared with whole workspace
  createdById     String?
  name            String
  caption         String?
  hashtags        String?  // space-separated
  firstComment    String?
  templateJson    String   // JSON {width,height,background,zones}
  contentJson     String   // JSON content map (incl. image data url)
  platform        String?
  scheduledAt     DateTime?
  status          String    @default("draft")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Post {
  id           String    @id @default(cuid())
  businessId   String
  templateId   String?
  caption      String?
  hashtags     String?
  firstComment String?
  mediaUrls    String    @default("[]")
  renderedUrl  String?   // final composited image (from template)
  content      String?   // JSON of the content used to fill the template
  mediaType    String    @default("image")
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  aiGenerated  Boolean   @default(false)
  source       String?   // "manual" | "news" | "template"
  sourceData   String?   // JSON: original news article / topic
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  accounts PostAccount[]
}

model PostAccount {
  id              String    @id @default(cuid())
  postId          String
  socialAccountId String
  platformPostId  String?
  status          String    @default("pending")
  error           String?
  publishedAt     DateTime?

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([postId, socialAccountId])
}
